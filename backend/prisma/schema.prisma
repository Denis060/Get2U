generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String            @id
  name                 String
  email                String            @unique
  emailVerified        Boolean           @default(false)
  image                String?
  role                 String            @default("customer")
  phone                String?
  address              String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionPlanId   String?
  adminRole            String?
  accounts             Account[]
  agentProfile         AgentProfile?
  sentMessages         Message[]         @relation("SentMessages")
  ordersAsAgent        Order[]           @relation("AgentOrders")
  ordersAsCustomer     Order[]           @relation("CustomerOrders")
  sessions             Session[]
  subscriptionPlan     SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  vehicles             Vehicle[]
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  target    String    @default("all")
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AgentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  rating            Float    @default(0)
  totalJobs         Int      @default(0)
  earnings          Float    @default(0)
  available         Boolean  @default(true)
  bio               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  applicationStatus String   @default("not_applied")
  idImageUrl        String?
  licenseImageUrl   String?
  rejectionReason   String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id                   String   @id @default(cuid())
  userId               String
  make                 String
  model                String
  year                 String?
  color                String?
  plate                String?
  location             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  carImageUrl          String?
  insuranceImageUrl    String?
  isVerified           Boolean  @default(false)
  registrationImageUrl String?
  orders               Order[]
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id             String            @id @default(cuid())
  customerId     String
  agentId        String?
  category       String
  serviceType    String
  status         String            @default("pending")
  pickupAddress  String?
  dropoffAddress String?
  packageType    String?
  courierService String?
  vehicleId      String?
  carLocation    String?
  description    String?
  estimatedPrice Float?
  finalPrice     Float?
  notes          String?
  completionNote String?
  agentLat       Float?
  agentLng       Float?
  agentUpdatedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  details        Json?
  messages       Message[]
  agent          User?             @relation("AgentOrders", fields: [agentId], references: [id])
  customer       User              @relation("CustomerOrders", fields: [customerId], references: [id])
  vehicle        Vehicle?          @relation(fields: [vehicleId], references: [id])
  inspections    OrderInspection[]

  @@index([customerId])
  @@index([agentId])
  @@index([status])
}

model OrderInspection {
  id        String   @id @default(cuid())
  orderId   String
  type      String
  photos    String[]
  notes     String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Message {
  id        String   @id @default(cuid())
  orderId   String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([orderId])
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  category      String
  price         Float
  interval      String
  features      String[]
  isPopular     Boolean  @default(false)
  stripePriceId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  users         User[]
}

model BusinessTier {
  id        String   @id @default(cuid())
  plan      String
  volume    String
  price     Float
  interval  String
  createdAt DateTime @default(now())
}

model ServiceFee {
  id          String   @id @default(cuid())
  name        String
  description String?
  baseFee     Float
  serviceType String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
